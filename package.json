{
  "name": "cashflow-saas",
  "version": "1.0.0",
  "private": true,
  "description": "SaaS B2B de controle financeiro de caixa para PMEs",
  "scripts": {
    "dev:backend": "dotenv -e .env -- pnpm --filter backend dev",
    "dev:frontend": "pnpm --filter frontend dev",
    "build:backend": "pnpm --filter backend build",
    "build:frontend": "pnpm --filter frontend build",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "db:generate": "pnpm --filter backend exec prisma generate",
    "db:migrate": "dotenv -e .env -- pnpm --filter backend exec prisma migrate dev",
    "db:seed": "dotenv -e .env -- pnpm --filter backend exec prisma db seed",
    "db:studio": "dotenv -e .env -- pnpm --filter backend exec prisma studio",
    "docker:up": "docker-compose -f infra/docker-compose.yml up -d",
    "docker:down": "docker-compose -f infra/docker-compose.yml down"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.0.0",
  "devDependencies": {
    "dotenv-cli": "^7.4.2"
  },
  "pnpm": {
    "overrides": {
      "reflect-metadata": "0.2.2"
    }
  }
}
